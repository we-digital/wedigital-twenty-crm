+  ({
+    __typename: 'PageLayoutWidget',
+    id: 'widget-id',
+    pageLayoutTabId: 'tab-id',
+    title: 'Dashboard',
+    type: WidgetType.IFRAME,
+    configuration: {
+      __typename: 'IframeConfiguration',
+      configurationType: 'IFRAME',
