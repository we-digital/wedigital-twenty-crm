--- /dev/null
+++ b/.github/workflows/build-and-push.yaml
@@ -0,0 +1,66 @@
+name: Build and Push CRM Image
+
+on:
+  push:
+    branches:
+      - main
+  workflow_dispatch:
+    inputs:
+      ref:
+        description: 'Git ref to build (branch, tag, or SHA)'
+        required: false
+        default: 'main'
+
+jobs:
+  build:
+    runs-on: ubuntu-latest
+    permissions:
+      contents: read
+      packages: write
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+        with:
+          ref: ${{ inputs.ref || github.sha }}
+          fetch-depth: 0
+
+      - name: Get upstream version
+        id: version
+        run: |
+          if [ -f .upstream-version ]; then
+            RAW_UPSTREAM_TAG=$(cat .upstream-version | tr -d '[:space:]')
+          else
+            RAW_UPSTREAM_TAG=$(git describe --tags --match 'v*' --match 'twenty/v*' --abbrev=0 2>/dev/null || echo "v0.0.0")
+          fi
+          UPSTREAM_TAG=${RAW_UPSTREAM_TAG##*/}
+          SHA_SHORT=$(git rev-parse --short HEAD)
+          echo "upstream_tag=${UPSTREAM_TAG}" >> "$GITHUB_OUTPUT"
+          echo "app_version=${UPSTREAM_TAG#v}" >> "$GITHUB_OUTPUT"
+          echo "sha_short=${SHA_SHORT}" >> "$GITHUB_OUTPUT"
+          echo "Built version: ${UPSTREAM_TAG} (source ref: ${RAW_UPSTREAM_TAG}, sha: ${SHA_SHORT})"
+
+      - name: Set up Docker Buildx
+        uses: docker/setup-buildx-action@v3
+
+      - name: Login to GitHub Container Registry
+        uses: docker/login-action@v3
+        with:
+          registry: ghcr.io
+          username: ${{ github.actor }}
+          password: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Build and push CRM image
+        uses: docker/build-push-action@v6
+        with:
+          context: .
+          file: packages/twenty-docker/twenty/Dockerfile
+          target: twenty
+          push: true
+          tags: |
+            ghcr.io/${{ github.repository }}:${{ steps.version.outputs.upstream_tag }}
+            ghcr.io/${{ github.repository }}:sha-${{ steps.version.outputs.sha_short }}
+            ghcr.io/${{ github.repository }}:latest
+          build-args: |
+            APP_VERSION=${{ steps.version.outputs.app_version }}
+          cache-from: type=gha
+          cache-to: type=gha,mode=max
