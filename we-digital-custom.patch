-
-const CRON_INTERVAL_MINUTES = Math.min(
-  Math.max(Number(process.env.CALENDAR_CRON_INTERVAL_MINUTES ?? 5), 1),
-  60 * 24,
-);
-
-const SECURITY_OVERLAP_MINUTES = 5;
