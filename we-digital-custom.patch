-      value: false,
-      expectToFail: false,
-    });
-  });
-
-  afterEach(async () => {
-    for (const id of createdTopicIds) {
-      await testDataSource
-        .query('DELETE FROM core."unsubscribeTopic" WHERE id = $1', [id])
