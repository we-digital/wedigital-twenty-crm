-const collectEmailContacts = async (
-  client: CoreApiClient,
-  contacts: LastContactAtByPersonId,
-): Promise<void> => {
-  let after: string | undefined;
-
-  do {
-    const { messageParticipants } = await client.query({
-      messageParticipants: {
-        __args: {
-          filter: { personId: { is: 'NOT_NULL' } },
