+  return (
+    <MenuItemAvatar
+      avatar={{
+        placeholder: workspaceMember.name.firstName,
+        avatarUrl: workspaceMember.avatarUrl,
+        placeholderColorSeed: workspaceMember.id,
+        size: 'md',
+        type: 'rounded',
+      }}
+      text={text}
+      iconButtons={[
+        {
+          Icon: IconPlus,
+          onClick: handleAddButtonClick,
+        },
+      ]}
