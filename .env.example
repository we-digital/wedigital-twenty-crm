# Twenty CRM Production Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
SERVER_DOMAIN=crm.example.com
SERVER_URL=https://crm.example.com
TAG=latest

# Widgets Configuration
WIDGETS_IMAGE=ghcr.io/we-digital/wedigital-twenty-crm/twenty-widgets:latest
VITE_TWENTY_URL=https://crm.example.com
VITE_SCANNER_POLL_URL=https://scanner.example.com/poll

# Let's Encrypt / ACME
ACME_EMAIL=admin@example.com

# PostgreSQL Database
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=twenty
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=your-secure-password-here

# Redis
REDIS_URL=redis://redis:6379

# Application Secret (generate a random string)
APP_SECRET=replace_me_with_a_random_string

# Feature Flags
DISABLE_DB_MIGRATIONS=false
DISABLE_CRON_JOBS_REGISTRATION=false

# S3 Storage (optional)
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_NAME=your-bucket-name
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com

# Google OAuth (optional)
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true
# AUTH_GOOGLE_CLIENT_ID=your-client-id
# AUTH_GOOGLE_CLIENT_SECRET=your-client-secret
# AUTH_GOOGLE_CALLBACK_URL=https://crm.example.com/auth/google/callback
# AUTH_GOOGLE_APIS_CALLBACK_URL=https://crm.example.com/auth/google/apis/callback

# Microsoft OAuth (optional)
# CALENDAR_PROVIDER_MICROSOFT_ENABLED=true
# MESSAGING_PROVIDER_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_CLIENT_ID=your-client-id
# AUTH_MICROSOFT_CLIENT_SECRET=your-client-secret
# AUTH_MICROSOFT_CALLBACK_URL=https://crm.example.com/auth/microsoft/callback
# AUTH_MICROSOFT_APIS_CALLBACK_URL=https://crm.example.com/auth/microsoft/apis/callback

# Email Configuration (optional)
# EMAIL_FROM_ADDRESS=contact@example.com
# EMAIL_FROM_NAME="John from Example"
# EMAIL_SYSTEM_ADDRESS=system@example.com
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=your-smtp-user
# EMAIL_SMTP_PASSWORD=your-smtp-password
